    {
      "parameters": {
        "jsCode": "// 1. 대상 노드에서 회사명을 가져옵니다.\nlet companyName = $('Edit Fields3').first().json.body[\"회사명\"];\n\n// 2. '(주)' 글자를 찾아 제거합니다. \n// / \\(주\\) /g -> 괄호와 (주)를 모두 찾아서 공백(\"\")으로 바꿉니다.\n// .trim() -> 앞뒤에 남을 수 있는 빈칸까지 정리합니다.\nif (companyName) {\n  companyName = companyName.replace(/\\(주\\)/g, \"\").trim();\n}\n\n// 3. 결과를 반환합니다.\nreturn [\n  {\n    json: {\n      기업코드 : $('Edit Fields3').first().json.body[\"기업코드\"],\n      오리지날회사명: $('Edit Fields3').first().json.body[\"회사명\"],\n      회사명: companyName\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "f42f2d4f-d0a0-4edb-a200-d88052ec35af",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// 1. 입력 데이터에서 기사 리스트(data)를 가져옵니다.\nconst articles = $input.first().json.data;\n\n// 2. 제목과 본문을 예쁘게 합칩니다.\nconst combinedText = articles.map((article, index) => {\n  return `[기사 ${index + 1}]\\n제목: ${article.제목}\\n본문: ${article.본문}\\n작성일: ${article.작성일}\\n`;\n}).join('\\n---\\n'); // 기사 사이에 구분선을 넣어서 AI가 읽기 편하게 만듭니다.\n\n// 3. 하나의 아이템으로 결과물을 반환합니다.\nreturn [\n  {\n    json: {\n      all_news_text: combinedText,\n      total_count: articles.length\n    }\n  }\n];"
      },
