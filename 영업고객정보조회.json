      "parameters": {
        "jsCode": "// 1. 우선 조건에 맞는 데이터만 필터링합니다.\nconst filteredData = $input.all()\n  .map(item => item.json.list) // list 안의 내용물만 추출\n  .filter(data => \n    data && \n    data.fs_nm === \"재무제표\" && \n    [\"매출액\", \"영업이익\"].includes(data.account_nm)\n  );\n\n// 2. 필터링된 결과가 있다면 하나의 아이템으로 묶어서 반환합니다.\nreturn [\n  {\n    json: {\n      results: filteredData,\n      count: filteredData.length,\n      updated_at: new Date()\n    }\n  }\n];"
